# IELTScoreUp Backend — Environment Variables
# Add these in Railway dashboard under Variables

ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key-here
PORT=3000

# Comma-separated list of frontend domains allowed to call this API.
# Without this set, CORS falls back to allowing any origin (not recommended for production).
ALLOWED_ORIGINS=https://ieltscoreup.com,https://www.ieltscoreup.com
